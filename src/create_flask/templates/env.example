# 复制为 .env 后按需修改；不要提交 .env 到版本库
ENV=development
FLASK_APP=wsgi:app

# 必填：生产环境务必改为随机强密钥
SECRET_KEY=change-me-please

# 数据库连接（默认 SQLite；可切换 PostgreSQL / MySQL）
DATABASE_URL=sqlite:///app.db
{% if use_redis %}
# Redis
REDIS_URL=redis://localhost:6379/0
{% endif %}{% if use_celery %}
# Celery（broker / result 默认指向 Redis）
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
{% endif %}
